import { z } from 'zod';

/**
 * User input payload
 */
export interface UserInput {
    /** Display name */
    name: string;
    /** Email address */
    email: string;
    /** Optional website */
    website?: string | null;
}

// Zod Schemas

export const UserInputSchema = z.object({
    name: z.string().min(1).max(20),
    email: z.string().email(),
    website: z.string().url().nullable(),
});

